alias c='clear'
alias sv='source ~/.bashrc'
alias gw='./gradlew'
alias pud='pushd'
alias pod='popd'
alias scancp='mount /dev/sdc2 /mnt/usb0 && cp /mnt/usb0/HPSCANS/scan* . && umount /dev/sdc2'
