{
    "suggest.autoTrigger": "trigger",
    "suggest.floatEnable": true,
    "suggest.maxCompleteItemCount": 100,
    "languageserver": {
        "groovy": {
            "command": "java",
            "args" : ["-jar",
                "/home/simon/.config/coc/extensions/groovy-language-server/build/libs/groovy-language-server-all.jar"],
            "filetypes": ["groovy"]
        }
    },
    "snippets.ultisnips.directories": [
        "mySnippets"
    ],
    "clangd.semanticHighlighting": true,
    "java.home": "/usr/lib64/jvm/java-14-openjdk",
    "java.import.gradle.wrapper.enabled": true,
    "java.configuration.runtimes": [
    	{
    		"name": "JavaSE-1.8",
			"path": "/usr/lib64/jvm/java-8-openjdk/",
			"default": true
		},
    	{
    		"name": "JavaSE-14",
			"path": "/usr/lib64/jvm/java-14-openjdk/"
		}
    ],
    "rust-client.disableRustup": true
}
